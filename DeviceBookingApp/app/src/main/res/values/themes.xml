<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.DeviceBookingApp" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="android:colorBackground">@color/bg_page</item>
        <item name="android:windowBackground">@color/bg_page</item>
        <item name="android:statusBarColor">@color/bg_page</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.DeviceBookingApp" parent="Base.Theme.DeviceBookingApp" />

    <!-- Card style -->
    <style name="AppCard">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/divider</item>
    </style>

    <!-- Primary button -->
    <style name="AppButton.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.02</item>

    </style>

    <!-- Outlined button -->
    <style name="AppButton.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_primary</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Danger button -->
    <style name="AppButton.Danger" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/status_red</item>
        <item name="android:textColor">@color/status_red</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- TextInput -->
    <style name="AppTextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/brand_primary</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxBackgroundColor">@color/bg_input</item>
    </style>
</resources>